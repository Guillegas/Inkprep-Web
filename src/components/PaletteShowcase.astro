---
import { getContent, type Lang } from "../i18n";
import showcase from "../assets/showcase.webp";
interface Props { lang: Lang; }
const { lang } = Astro.props;
const c = getContent(lang);
---
<section class="py-20">
  <div class="reveal mx-auto max-w-2xl px-5 text-center">
    <span class="text-xs font-semibold tracking-[0.25em] text-white/60">{c.showcase.label}</span>
    <h2 class="mt-4 font-display text-3xl font-bold sm:text-4xl">{c.showcase.heading}</h2>
    <p class="mt-4 text-lg text-white/60">{c.showcase.body}</p>
  </div>
  <div class="reveal relative mt-12 w-full">
    <img
      src={showcase.src}
      alt="A color tattoo with the recommended inks identified for each color"
      class="w-full"
      loading="lazy"
      width={showcase.width}
      height={showcase.height}
    />
    <div class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-black to-transparent sm:h-40"></div>
    <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black to-transparent sm:h-40"></div>
  </div>
</section>
