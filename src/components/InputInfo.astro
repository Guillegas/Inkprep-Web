---
import { getContent, type Lang } from "../i18n";
import GlassCard from "./GlassCard.astro";
interface Props { lang: Lang; }
const { lang } = Astro.props;
const c = getContent(lang);
---
<section class="px-5 py-20">
  <div class="mx-auto grid max-w-5xl gap-5 md:grid-cols-2">
    <GlassCard class="reveal flex flex-col p-8">
      <span class="flex h-14 w-14 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-3xl" role="img" aria-label={c.input.cleanTitle}>{c.input.cleanEmoji}</span>
      <h2 class="mt-6 font-display text-2xl font-bold leading-tight">{c.input.cleanTitle}</h2>
      <p class="mt-3 text-white/60">{c.input.cleanBody}</p>
    </GlassCard>
    <GlassCard class="reveal flex flex-col p-8">
      <span class="flex h-14 w-14 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-3xl" role="img" aria-label={c.input.accuracyTitle}>{c.input.accuracyEmoji}</span>
      <h2 class="mt-6 font-display text-2xl font-bold leading-tight">{c.input.accuracyTitle}</h2>
      <p class="mt-3 text-white/60">{c.input.accuracyBody}</p>
    </GlassCard>
  </div>
</section>
