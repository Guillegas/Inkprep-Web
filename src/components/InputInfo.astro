---
import { getContent, type Lang } from "../i18n";
import GlassCard from "./GlassCard.astro";
interface Props { lang: Lang; }
const { lang } = Astro.props;
const c = getContent(lang);
---
<section class="px-5 py-20">
  <div class="mx-auto grid max-w-5xl gap-5 md:grid-cols-2">
    <GlassCard class="reveal p-7">
      <span class="text-xs font-semibold tracking-[0.25em] text-white/60">{c.input.label}</span>
      <h2 class="mt-4 font-display text-2xl font-bold">{c.input.heading}</h2>
      <p class="mt-3 text-white/60">{c.input.body}</p>
    </GlassCard>
    <GlassCard class="reveal p-7">
      <h3 class="text-lg font-semibold text-white/90">{c.input.disclaimerTitle}</h3>
      <p class="mt-3 text-white/60">{c.input.disclaimer}</p>
    </GlassCard>
  </div>
</section>
