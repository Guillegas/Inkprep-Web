---
import { getContent, type Lang } from "../i18n";
import Glow from "./Glow.astro";
import PhoneDevice from "./PhoneDevice.astro";
import StoreButtons from "./StoreButtons.astro";
import screen1 from "../assets/screens/screen-1.png";
import screen2 from "../assets/screens/screen-2.png";
interface Props { lang: Lang; }
const { lang } = Astro.props;
const c = getContent(lang);
---
<section class="relative flex min-h-screen items-center overflow-hidden px-5 pb-16 pt-32">
  <Glow color="var(--color-ink-crimson)" class="left-1/2 top-1/2 h-[34rem] w-[34rem] -translate-x-1/2 -translate-y-1/2 opacity-30" />
  <div class="reveal mx-auto flex max-w-2xl flex-col items-center text-center">
    <h1 class="font-display text-4xl font-extrabold leading-[1.1] sm:text-5xl lg:text-6xl">
      {c.hero.heading} <em class="not-italic text-[var(--color-ink-crimson)]">{c.hero.headingEm}</em>
    </h1>

    <!-- Two crossed iPhones -->
    <div class="relative mx-auto mt-14 h-[360px] w-[260px] sm:h-[480px] sm:w-[380px]">
      <div class="absolute left-0 top-6 h-[312px] w-[154px] -rotate-[10deg] sm:h-[434px] sm:w-[214px]">
        <div class="origin-top-left scale-[0.36] sm:scale-[0.5]">
          <PhoneDevice src={screen1.src} />
        </div>
      </div>
      <div class="absolute right-0 top-0 z-10 h-[312px] w-[154px] rotate-[10deg] sm:h-[434px] sm:w-[214px]">
        <div class="origin-top-left scale-[0.36] sm:scale-[0.5]">
          <PhoneDevice src={screen2.src} video="/screens/demo.mp4" />
        </div>
      </div>
    </div>

    <div class="mt-10">
      <StoreButtons comingSoonLabel={c.comingSoon} />
    </div>
  </div>
</section>
