---
import { getContent, type Lang } from "../i18n";
import { ANALYTICS_DOMAIN, ANALYTICS_SRC } from "../config";
interface Props { lang: Lang; }
const { lang } = Astro.props;
const c = getContent(lang);
const privacyHref = lang === "es" ? "/es/privacy" : "/privacy";
---
<div
  id="consent-banner"
  class="glass fixed inset-x-3 bottom-3 z-[100] hidden rounded-2xl p-4 sm:inset-x-auto sm:right-4 sm:max-w-sm"
  role="dialog"
  aria-live="polite"
  aria-label="Cookie consent"
>
  <p class="text-sm text-white/80">
    {c.consent.text}
    <a href={privacyHref} class="underline hover:text-white">{c.consent.privacyLabel}</a>.
  </p>
  <div class="mt-3 flex gap-2">
    <button id="consent-accept" type="button" class="flex-1 rounded-xl bg-white px-4 py-2 text-sm font-semibold text-black transition hover:bg-white/90">{c.consent.accept}</button>
    <button id="consent-reject" type="button" class="flex-1 rounded-xl border border-white/15 px-4 py-2 text-sm font-semibold text-white/80 transition hover:text-white">{c.consent.reject}</button>
  </div>
</div>

<script define:vars={{ ANALYTICS_DOMAIN, ANALYTICS_SRC }}>
  const KEY = "inkprep-consent";
  const banner = document.getElementById("consent-banner");

  const loadAnalytics = () => {
    if (!ANALYTICS_DOMAIN) return; // no provider configured yet
    if (document.getElementById("analytics-script")) return;
    const s = document.createElement("script");
    s.id = "analytics-script";
    s.defer = true;
    s.setAttribute("data-domain", ANALYTICS_DOMAIN);
    s.src = ANALYTICS_SRC;
    document.head.appendChild(s);
  };

  const choice = localStorage.getItem(KEY);
  if (choice === "accepted") {
    loadAnalytics();
  } else if (choice !== "rejected") {
    banner?.classList.remove("hidden");
  }

  document.getElementById("consent-accept")?.addEventListener("click", () => {
    localStorage.setItem(KEY, "accepted");
    banner?.classList.add("hidden");
    loadAnalytics();
  });
  document.getElementById("consent-reject")?.addEventListener("click", () => {
    localStorage.setItem(KEY, "rejected");
    banner?.classList.add("hidden");
  });
</script>
