---
interface Props {
  color: string;
  class?: string;
}
const { color, class: className = "" } = Astro.props;
---
<div
  class={`pointer-events-none absolute -z-10 rounded-full blur-[120px] opacity-40 ${className}`}
  style={`background: radial-gradient(circle, ${color} 0%, transparent 70%);`}
  aria-hidden="true"
>
</div>
